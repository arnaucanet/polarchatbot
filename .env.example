APP_ENV=production
PORT=3000
OPENAI_API_KEY=replace_with_your_openai_key
OPENAI_MODEL=gpt-4o-mini

# PlanetScale (recommended):
# DATABASE_URL=mysql://username:password@aws.connect.psdb.cloud/db_name?sslaccept=strict
DATABASE_URL=

# Fallback manual DB config (if not using DATABASE_URL):
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chatbot_db
DB_USER=root
DB_PASS=replace_with_db_password
DB_SSL_REQUIRED=1

ALLOWED_ORIGINS=https://your-frontend-domain.com
MAX_MESSAGE_LENGTH=600
CHAT_RATE_LIMIT_MAX=20
CHAT_RATE_LIMIT_WINDOW=60
DATA_RATE_LIMIT_MAX=120
DATA_RATE_LIMIT_WINDOW=60

ENABLE_INSTALLER=0
INSTALL_TOKEN=replace_with_install_token
